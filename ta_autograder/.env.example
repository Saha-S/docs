# Copy this file to .env and fill in your values.
# Never commit the .env file to version control.

# Required: your OpenAI API key
OPENAI_API_KEY=sk-...

# Optional overrides (defaults shown)
OPENAI_MODEL=gpt-4o

# Seconds to wait between API calls (avoids rate-limit errors)
API_CALL_DELAY=2.0

# Path to the folder that contains one sub-folder per student
SUBMISSIONS_FOLDER=all

# Path for the output Excel file
OUTPUT_EXCEL=grading_results.xlsx
